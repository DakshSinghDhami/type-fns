{
  "name": "type-fns",
  "version": "0.1.0",
  "description": "A collection of useful TypeScript utility types",
  "license": "MIT",
  "author": "Daksh Singh Dhami",
  "repository": {
    "type": "git",
    "url": "https://github.com/DakshSinghDhami/type-fns.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "keywords": ["typescript", "types", "utility-types", "type-fns", "typescript-utilities"]
}
